@startuml HCBS_ERD
' =====================================================================
' Horizon Cinemas Booking System (HCBS)  ——  Entity Relationship Diagram
' Target grade band: 85 - 100
' Normal Form     : 3NF (intentional snapshot fields are noted in comments)
' Distribution    : Each entity carries a globally unique surrogate key
'                   (xxx_id) so it can be sharded / replicated across nodes.
' =====================================================================

skinparam linetype ortho
skinparam shadowing false
skinparam classFontName "Segoe UI"
skinparam classFontSize 12
skinparam classAttributeFontSize 11
skinparam roundCorner 6
hide circle
hide methods

' ---------- Legend ------------------------------------------------------
legend top left
  <b>Notation</b>
  <u>attr</u>      Primary Key (PK)
  attr (FK)  Foreign Key (FK)
  *attr      NOT NULL
  •attr      Unique
  Cardinality reads: ParentSide  --  ChildSide
  e.g.  "1" -- "0..*"   means  one-to-many
end legend

' =====================================================================
'  CORE LOCATION / CINEMA HIERARCHY
' =====================================================================
entity "City" as City {
  <u>* city_id : BIGINT</u>
  --
  •* city_name   : VARCHAR(60)
  * country      : VARCHAR(60)
  * timezone     : VARCHAR(40)
  * default_currency : VARCHAR(3)
}

entity "Cinema" as Cinema {
  <u>* cinema_id : BIGINT</u>
  --
  * city_id (FK -> City.city_id) : BIGINT
  •* name    : VARCHAR(120)
  * address  : VARCHAR(255)
  * active   : BOOLEAN
}

entity "Screen" as Screen {
  <u>* screen_id : BIGINT</u>
  --
  * cinema_id (FK -> Cinema.cinema_id) : BIGINT
  * screen_number : INT
  * hall_type     : ENUM(REGULAR,IMAX,PREMIUM)
  * capacity      : INT  /* 50..120 */
  -- UNIQUE (cinema_id, screen_number) --
}

entity "Seat" as Seat {
  <u>* seat_id : BIGINT</u>
  --
  * screen_id (FK -> Screen.screen_id) : BIGINT
  * seat_number  : VARCHAR(8)
  * seat_type    : ENUM(STANDARD,PREMIUM,CENTER)
  * hall_section : ENUM(LOWER_HALL,UPPER_GALLERY)
  * row_label    : VARCHAR(4)
  * col_index    : INT
  -- UNIQUE (screen_id, seat_number) --
}

' =====================================================================
'  PRICING (3NF: avoids hard-coding £5/£6/£7 in business code)
' =====================================================================
entity "PriceRule" as PriceRule {
  <u>* price_rule_id : BIGINT</u>
  --
  * city_id (FK -> City.city_id) : BIGINT
  * hall_section : ENUM(LOWER_HALL,UPPER_GALLERY)
  * time_slot    : ENUM(MORNING,AFTERNOON,EVENING)
  * seat_type    : ENUM(STANDARD,PREMIUM,CENTER)
  * base_price   : DECIMAL(10,2)
  * effective_from : DATE
  * effective_to   : DATE
  -- UNIQUE (city_id,hall_section,time_slot,seat_type,effective_from) --
}

' =====================================================================
'  FILMS & SCREENINGS
' =====================================================================
entity "Film" as Film {
  <u>* film_id : BIGINT</u>
  --
  * title         : VARCHAR(200)
  description     : VARCHAR(1500)
  actors          : VARCHAR(1000)
  directors       : VARCHAR(1000)
  * genre         : VARCHAR(60)
  * age_rating    : VARCHAR(8)
  * duration_minutes : INT
  release_date    : DATE
  content_advice  : VARCHAR(1000)
  poster_url      : VARCHAR(500)
}

entity "Screening" as Screening {
  <u>* screening_id : BIGINT</u>
  --
  * film_id   (FK -> Film.film_id)   : BIGINT
  * screen_id (FK -> Screen.screen_id) : BIGINT
  * screening_date : DATE
  * start_time     : TIME
  * end_time       : TIME
  * screening_type : ENUM(REGULAR_2D,REGULAR_3D,ADVANCE_PREVIEW_2D,ADVANCE_PREVIEW_3D)
  * time_slot      : ENUM(MORNING,AFTERNOON,EVENING)
  -- UNIQUE (screen_id, screening_date, start_time) --
}

' =====================================================================
'  USERS & AUTH
' =====================================================================
entity "UserAccount" as UserAccount {
  <u>* user_id : BIGINT</u>
  --
  •* username   : VARCHAR(60)
  •* email      : VARCHAR(120)
  * password_hash : VARCHAR(255)
  * full_name   : VARCHAR(120)
  * role        : ENUM(BOOKING_STAFF,ADMIN,MANAGER)
  * active      : BOOLEAN
  created_at    : TIMESTAMP
}

' =====================================================================
'  BOOKINGS  (core business artefact)
' =====================================================================
entity "Booking" as Booking {
  <u>* booking_id : BIGINT</u>
  --
  •* booking_reference : VARCHAR(40)
  * screening_id (FK -> Screening.screening_id) : BIGINT
  * created_by_user_id (FK -> UserAccount.user_id) : BIGINT
  * customer_name  : VARCHAR(120)
  * customer_email : VARCHAR(120)
  * booking_date   : TIMESTAMP
  * total_cost     : DECIMAL(10,2)
  * status         : ENUM(CONFIRMED,CANCELLED,REFUND_PENDING,REFUNDED)
  * vip            : BOOLEAN
}

entity "BookingSeat" as BookingSeat {
  <u>* booking_seat_id : BIGINT</u>
  --
  * booking_id (FK -> Booking.booking_id) : BIGINT
  * seat_id    (FK -> Seat.seat_id)       : BIGINT
  * ticket_price : DECIMAL(10,2)  /* snapshot @ booking time */
  -- UNIQUE (booking_id, seat_id) --
}

entity "CancellationRecord" as Cancellation {
  <u>* cancellation_id : BIGINT</u>
  --
  * booking_id (FK -> Booking.booking_id) : BIGINT
  * refund_amount       : DECIMAL(12,2)
  cancellation_reason   : VARCHAR(500)
  * cancelled_at        : TIMESTAMP
  * refunded            : BOOLEAN
  cancelled_by_user_id (FK -> UserAccount.user_id) : BIGINT
}

' =====================================================================
'  FOOD ORDERING
' =====================================================================
entity "FoodItem" as FoodItem {
  <u>* food_item_id : BIGINT</u>
  --
  •* name     : VARCHAR(120)
  * category  : ENUM(FOOD,DRINK,SNACK,COMBO)
  * price     : DECIMAL(10,2)
  image_url   : VARCHAR(255)
  * active    : BOOLEAN
}

entity "FoodOrder" as FoodOrder {
  <u>* food_order_id : BIGINT</u>
  --
  * booking_id (FK -> Booking.booking_id) : BIGINT
  * delivery_method : ENUM(COUNTER_PICKUP,SEAT_DELIVERY)
  * status          : ENUM(PENDING,PREPARING,READY,DELIVERED,CANCELLED)
  * order_time      : TIMESTAMP
  * total_cost      : DECIMAL(10,2)
}

entity "FoodOrderItem" as FoodOrderItem {
  <u>* food_order_item_id : BIGINT</u>
  --
  * food_order_id (FK -> FoodOrder.food_order_id) : BIGINT
  * food_item_id  (FK -> FoodItem.food_item_id)   : BIGINT
  * quantity   : INT
  * unit_price : DECIMAL(10,2)  /* snapshot */
  * line_total : DECIMAL(10,2)
}

' =====================================================================
'  AUDIT & MANAGER FEEDBACK  (compliance / governance)
' =====================================================================
entity "AuditLog" as AuditLog {
  <u>* audit_log_id : BIGINT</u>
  --
  * action      : VARCHAR(60)
  * actor_user_id (FK -> UserAccount.user_id) : BIGINT
  entity_type   : VARCHAR(60)
  entity_id     : BIGINT
  reference     : VARCHAR(80)
  amount        : DECIMAL(10,2)
  old_status    : VARCHAR(32)
  new_status    : VARCHAR(32)
  summary       : VARCHAR(500)
  details       : VARCHAR(2500)
  ip_address    : VARCHAR(60)
  * created_at  : TIMESTAMP
}

entity "ManagerFeedback" as ManagerFeedback {
  <u>* feedback_id : BIGINT</u>
  --
  * manager_user_id (FK -> UserAccount.user_id) : BIGINT
  * title      : VARCHAR(200)
  comment      : VARCHAR(2500)
  * created_at : TIMESTAMP
}

' =====================================================================
'  RELATIONSHIPS  (cardinality is on each end)
' =====================================================================
City          "1"  --  "1..*" Cinema          : has >
City          "1"  --  "1..*" PriceRule       : applies >
Cinema        "1"  --  "1..6" Screen          : owns >
Screen        "1"  --  "50..120" Seat         : contains >
Screen        "1"  --  "0..*" Screening       : hosts >
Film          "1"  --  "0..*" Screening       : scheduled as >
Screening     "1"  --  "0..*" Booking         : sold via >
UserAccount   "1"  --  "0..*" Booking         : created by >
Booking       "1"  --  "1..*" BookingSeat     : contains >
Seat          "1"  --  "0..*" BookingSeat     : reserved as >
Booking       "1"  --  "0..1" Cancellation    : cancelled by >
UserAccount   "1"  --  "0..*" Cancellation    : performed by >
Booking       "1"  --  "0..*" FoodOrder       : ordered with >
FoodOrder     "1"  --  "1..*" FoodOrderItem   : contains >
FoodItem      "1"  --  "0..*" FoodOrderItem   : referenced by >
UserAccount   "1"  --  "0..*" AuditLog        : produces >
UserAccount   "1"  --  "0..*" ManagerFeedback : writes >

note bottom of BookingSeat
  N : M between Booking and Seat
  resolved through this junction;
  unique(booking_id, seat_id) prevents
  the same seat being added twice.
end note

' =====================================================================
'  KEY DESIGN NOTES  (mandatory short explanation for Exercise 1)
' =====================================================================

note as N_City
  <b>[1] City 实体拆分理由</b>
  ----
  将城市信息从 Cinema 中分离出来，
  消除传递依赖 (city -> timezone /
  currency / 价格档位)，符合 3NF；
  同时支撑 London 的差异化定价以及
  未来在新城市的扩张需求 —— 新增
  一个城市只需向 City / PriceRule
  插入数据，无需改动 Cinema 结构。
end note

note as N_PriceRule
  <b>[2] PriceRule 定价策略</b>
  ----
  将 £5 / £6 / £7 等价格映射从
  业务代码移至数据库表，通过复合
  唯一键 (city_id, hall_section,
  time_slot, seat_type, effective_from)
  支持灵活、可演进、可审计的定价；
  Cinema 实体不再承载价格语义，
  彻底消除原 city -> price 的传递依赖。
end note

note as N_Snapshot
  <b>[3] BookingSeat 快照字段</b>
  ----
  BookingSeat.ticket_price 与
  FoodOrderItem.unit_price 故意
  保留为业务快照，避免历史订单价格
  被未来 PriceRule 调价回溯污染。
  这是 3NF 的合理反范式特例
  (audit / billing 行业惯例)。
end note

note as N_Sharding
  <b>[4] 分布式分片维度</b>
  ----
  所有实体均使用全局唯一代理键
  xxx_id (BIGINT)，无循环外键依赖，
  天然适配分布式持久化：
   - Cinema / PriceRule 按 city_id 分片
   - Booking / Screening 按 screening_id 分片
   - UserAccount 按 role 分片
   - AuditLog 按 created_at 时间分片
  业务幂等键: booking_reference / username / email
end note

@enduml
